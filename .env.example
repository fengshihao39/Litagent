# Required API keys
DEEPSEEK_API_KEY=your_deepseek_api_key
IEEE_API_KEY=your_ieee_api_key

# Optional runtime settings
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
LITAGENT_FRONTEND_API_URL=http://localhost:8000
IMAGE_BACKGROUND="https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?auto=format&fit=crop&w=1400&q=80"

# Provider API base URLs
ARXIV_API_BASE=https://export.arxiv.org/api/query
CROSSREF_API_BASE=https://api.crossref.org/works
IEEE_API_BASE=https://ieeexploreapi.ieee.org/api/v1/search/articles
SEMANTIC_SCHOLAR_API_BASE=https://api.semanticscholar.org/graph/v1/paper/search

# Provider User-Agent
PROVIDER_USER_AGENT="Litagent/1.0 (mailto:your-email@example.com)"
